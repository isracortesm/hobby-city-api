{
    "kind": "collectionType",
    "collectionName": "competition_results",
    "info": {
        "singularName": "competition-result",
        "pluralName": "competition-results",
        "displayName": "CompetitionResult"
    },
    "options": {
        "draftAndPublish": true
    },
    "pluginOptions": {},
    "attributes": {
        "order": {
            "type": "integer"
        },
        "totalPoints": {
            "type": "integer"
        },
        "evaluations": {
            "type": "component",
            "component": "competition.evaluation",
            "repeatable": true
        },
        "model": {
            "type": "relation",
            "relation": "oneToOne",
            "target": "api::competition-model.competition-model"
        },
        "reviewer": {
            "type": "relation",
            "relation": "oneToOne",
            "target": "api::activity-collaborator.activity-collaborator"
        },
        "batch": {
            "type": "relation",
            "relation": "oneToOne",
            "target": "api::competition-batch.competition-batch"
        },
        "competition": {
            "type": "relation",
            "relation": "manyToOne",
            "target": "api::competition.competition",
            "inversedBy": "results"
        }
    }
}
