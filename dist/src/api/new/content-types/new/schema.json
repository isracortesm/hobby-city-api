{
    "kind": "collectionType",
    "collectionName": "news",
    "info": {
        "singularName": "new",
        "pluralName": "news",
        "displayName": "New"
    },
    "options": {
        "draftAndPublish": true
    },
    "pluginOptions": {},
    "attributes": {
        "title": {
            "type": "string",
            "required": true
        },
        "subtitle": {
            "type": "string",
            "required": true
        },
        "content": {
            "type": "richtext",
            "required": true
        },
        "thumbnail": {
            "type": "media",
            "multiple": false,
            "allowedTypes": [
                "images",
                "files"
            ]
        },
        "order": {
            "type": "integer",
            "required": true,
            "default": 0
        },
        "user": {
            "type": "relation",
            "relation": "oneToOne",
            "target": "plugin::users-permissions.user"
        },
        "event": {
            "type": "relation",
            "relation": "manyToOne",
            "target": "api::event.event",
            "inversedBy": "news"
        }
    }
}
