{
    "kind": "collectionType",
    "collectionName": "activities",
    "info": {
        "singularName": "activity",
        "pluralName": "activities",
        "displayName": "Activity"
    },
    "options": {
        "draftAndPublish": true
    },
    "pluginOptions": {},
    "attributes": {
        "name": {
            "type": "string",
            "required": true
        },
        "shortDescription": {
            "type": "string",
            "required": true
        },
        "description": {
            "type": "richtext",
            "required": true
        },
        "image": {
            "type": "media",
            "multiple": false,
            "allowedTypes": [
                "images",
                "files"
            ]
        },
        "costType": {
            "type": "enumeration",
            "required": true,
            "default": "free",
            "enum": [
                "free",
                "paid"
            ]
        },
        "cost": {
            "type": "decimal"
        },
        "startDate": {
            "type": "datetime",
            "required": true
        },
        "endDate": {
            "type": "datetime",
            "required": true
        },
        "capacity": {
            "type": "integer",
            "required": true,
            "default": 0
        },
        "participantsCount": {
            "type": "integer",
            "required": true,
            "default": 0
        },
        "hasActiveRegister": {
            "type": "boolean",
            "required": true,
            "default": true
        },
        "category": {
            "type": "relation",
            "relation": "oneToOne",
            "target": "api::activity-category.activity-category"
        },
        "event": {
            "type": "relation",
            "relation": "manyToOne",
            "target": "api::event.event",
            "inversedBy": "activities"
        },
        "collaborators": {
            "type": "relation",
            "relation": "oneToMany",
            "target": "api::activity-collaborator.activity-collaborator",
            "mappedBy": "activity"
        }
    }
}
