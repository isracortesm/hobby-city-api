{
    "kind": "collectionType",
    "collectionName": "competition_categories",
    "info": {
        "singularName": "competition-category",
        "pluralName": "competition-categories",
        "displayName": "CompetitionCategory"
    },
    "options": {
        "draftAndPublish": false
    },
    "pluginOptions": {},
    "attributes": {
        "name": {
            "type": "string",
            "required": true
        },
        "description": {
            "type": "text"
        },
        "competition": {
            "type": "relation",
            "relation": "manyToOne",
            "target": "api::competition.competition",
            "inversedBy": "categories"
        },
        "batches": {
            "type": "relation",
            "relation": "oneToMany",
            "target": "api::competition-batch.competition-batch",
            "mappedBy": "category"
        },
        "criterias": {
            "type": "relation",
            "relation": "oneToMany",
            "target": "api::competition-criteria.competition-criteria",
            "mappedBy": "category"
        }
    }
}
