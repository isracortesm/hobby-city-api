{
    "kind": "collectionType",
    "collectionName": "events",
    "info": {
        "singularName": "event",
        "pluralName": "events",
        "displayName": "Event"
    },
    "options": {
        "draftAndPublish": true
    },
    "pluginOptions": {},
    "attributes": {
        "eventId": {
            "type": "uid",
            "required": true,
            "regex": "^[a-zA-Z0-9]{8}$"
        },
        "name": {
            "type": "string",
            "required": true
        },
        "shortDescription": {
            "type": "string",
            "required": true
        },
        "description": {
            "type": "richtext",
            "required": true
        },
        "category": {
            "type": "relation",
            "relation": "oneToOne",
            "target": "api::event-category.event-category"
        },
        "image": {
            "type": "media",
            "multiple": false,
            "allowedTypes": [
                "images",
                "files"
            ]
        },
        "startDate": {
            "type": "datetime",
            "required": true
        },
        "endDate": {
            "type": "datetime",
            "required": true
        },
        "costType": {
            "type": "enumeration",
            "required": true,
            "default": "free",
            "enum": [
                "free",
                "paid"
            ]
        },
        "cost": {
            "type": "decimal"
        },
        "capacity": {
            "type": "integer"
        },
        "participationCount": {
            "type": "integer",
            "required": true,
            "default": 0
        },
        "likes": {
            "type": "biginteger",
            "required": true,
            "default": "0"
        },
        "address": {
            "type": "component",
            "component": "place.address",
            "repeatable": false
        },
        "user": {
            "type": "relation",
            "relation": "oneToOne",
            "target": "plugin::users-permissions.user"
        },
        "news": {
            "type": "relation",
            "relation": "oneToMany",
            "target": "api::new.new",
            "mappedBy": "event"
        },
        "activities": {
            "type": "relation",
            "relation": "oneToMany",
            "target": "api::activity.activity",
            "mappedBy": "event"
        },
        "collaborators": {
            "type": "relation",
            "relation": "oneToMany",
            "target": "api::event-collaborator.event-collaborator",
            "mappedBy": "event"
        },
        "socialNetworks": {
            "type": "relation",
            "relation": "oneToMany",
            "target": "api::event-netwok.event-netwok",
            "mappedBy": "event"
        }
    }
}
