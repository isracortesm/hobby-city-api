{
  "kind": "collectionType",
  "collectionName": "activity_collaborators",
  "info": {
    "singularName": "activity-collaborator",
    "pluralName": "activity-collaborators",
    "displayName": "ActivityCollaborator"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "role": {
      "type": "enumeration",
      "required": true,
      "default": "other",
      "enum": [
        "admin",
        "judge",
        "speaker",
        "instructor",
        "other"
      ]
    },
    "description": {
      "type": "string"
    },
    "activity": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::activity.activity",
      "inversedBy": "collaborators"
    },
    "user": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "plugin::users-permissions.user"
    }
  }
}
