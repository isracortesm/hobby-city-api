{
  "kind": "collectionType",
  "collectionName": "events",
  "info": {
    "singularName": "event",
    "pluralName": "events",
    "displayName": "Event"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "eventId": {
      "type": "uid",
      "required": true,
      "regex": "^[a-zA-Z0-9]{8}$"
    },
    "name": {
      "type": "string",
      "required": true
    },
    "description": {
      "type": "richtext",
      "required": true
    },
    "image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files"
      ]
    },
    "costType": {
      "type": "enumeration",
      "required": true,
      "default": "free",
      "enum": [
        "free",
        "paid"
      ]
    },
    "cost": {
      "type": "decimal"
    },
    "startDate": {
      "type": "datetime",
      "required": true
    },
    "endDate": {
      "type": "datetime",
      "required": true
    },
    "likes": {
      "type": "biginteger",
      "required": true,
      "default": "0"
    },
    "socialNetworks": {
      "type": "component",
      "component": "social.network",
      "repeatable": true
    },
    "address": {
      "type": "component",
      "component": "place.address",
      "repeatable": false
    },
    "news": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::new.new",
      "mappedBy": "event"
    },
    "activities": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::activity.activity",
      "mappedBy": "event"
    },
    "collaborators": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::event-collaborator.event-collaborator",
      "mappedBy": "event"
    },
    "assistants": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::event-assistant.event-assistant",
      "mappedBy": "event"
    }
  }
}
