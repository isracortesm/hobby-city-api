{
  "kind": "collectionType",
  "collectionName": "activities",
  "info": {
    "singularName": "activity",
    "pluralName": "activities",
    "displayName": "Activity"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "description": {
      "type": "richtext",
      "required": true
    },
    "image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files"
      ]
    },
    "costType": {
      "type": "enumeration",
      "enum": [
        "free",
        "paid"
      ]
    },
    "cost": {
      "type": "decimal"
    },
    "startDate": {
      "type": "datetime",
      "required": true
    },
    "endDate": {
      "type": "datetime",
      "required": true
    },
    "activityType": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::event-type.event-type"
    },
    "event": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::event.event",
      "inversedBy": "activities"
    },
    "collaborators": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::activity-collaborator.activity-collaborator",
      "mappedBy": "activity"
    },
    "participants": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::activity-participant.activity-participant",
      "mappedBy": "activity"
    }
  }
}
