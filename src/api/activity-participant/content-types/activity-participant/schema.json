{
  "kind": "collectionType",
  "collectionName": "activity_participants",
  "info": {
    "singularName": "activity-participant",
    "pluralName": "activity-participants",
    "displayName": "ActivityParticipant"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "statusName": {
      "type": "enumeration",
      "required": true,
      "default": "registered",
      "enum": [
        "registered",
        "paid"
      ]
    },
    "checkIn": {
      "type": "boolean",
      "required": true,
      "default": false
    },
    "activity": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::activity.activity"
    },
    "user": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "plugin::users-permissions.user"
    }
  }
}
